{
  "swagger": "2.0",
  "info": {
    "title": "My API",
    "description": "Product API with Orders",
    "version": "1.0.0"
  },
  "host": "newpro-b978.onrender.com",
  "basePath": "/",
  "schemes": ["https"],
  "paths": {
    "/products/": {
      "get": {
        "description": "Get all products",
        "produces": ["application/json"],
        "responses": {
          "200": { "description": "OK" }
        }
      },
      "post": {
        "description": "Create a new product",
        "consumes": ["application/json"],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["productName", "price", "stackQuantity"],
              "properties": {
                "productName": { "type": "string", "example": "iPhone 15" },
                "description": { "type": "string", "example": "Latest Apple smartphone" },
                "price": { "type": "number", "format": "float", "example": 999.99 },
                "stackQuantity": { "type": "integer", "example": 50 }
              }
            }
          }
        ],
        "responses": {
          "201": { "description": "Created" },
          "500": { "description": "Internal Server Error" }
        }
      }
    },

    "/products/{id}": {
      "get": {
        "description": "Get a single product",
        "produces": ["application/json"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string", "example": "65f1a2b3c4d5e6f789012345" }
        ],
        "responses": {
          "200": { "description": "OK" },
          "400": { "description": "Invalid ID" },
          "404": { "description": "Product not found" }
        }
      },
      "put": {
        "description": "Update a product",
        "consumes": ["application/json"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "productName": { "type": "string", "example": "Samsung Galaxy" },
                "description": { "type": "string", "example": "Updated description" },
                "price": { "type": "number", "example": 799.99 },
                "stackQuantity": { "type": "integer", "example": 30 }
              }
            }
          }
        ],
        "responses": {
          "204": { "description": "No Content" },
          "400": { "description": "Bad Request" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "delete": {
        "description": "Delete a product",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "204": { "description": "No Content" },
          "404": { "description": "Not Found" },
          "500": { "description": "Internal Server Error" }
        }
      }
    },

    "/orders/": {
      "get": {
        "description": "Get all orders",
        "produces": ["application/json"],
        "responses": { "200": { "description": "OK" } }
      },
      "post": {
        "description": "Create a new order",
        "consumes": ["application/json"],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["user_id", "order_date", "total_amount", "status"],
              "properties": {
                "user_id": { "type": "integer", "example": 236 },
                "order_date": { "type": "string", "format": "date", "example": "2026-03-03" },
                "total_amount": { "type": "number", "example": 100 },
                "status": { "type": "string", "example": "pending" }
              }
            }
          }
        ],
        "responses": {
          "201": { "description": "Created" },
          "500": { "description": "Internal Server Error" }
        }
      }
    },

    "/orders/{id}": {
      "get": {
        "description": "Get a single order",
        "produces": ["application/json"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string", "example": "69be5e72290d787fff33e90b" }
        ],
        "responses": {
          "200": { "description": "OK" },
          "404": { "description": "Order not found" }
        }
      },
      "put": {
        "description": "Update an order",
        "consumes": ["application/json"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "user_id": { "type": "integer", "example": 236 },
                "order_date": { "type": "string", "format": "date", "example": "2026-03-03" },
                "total_amount": { "type": "number", "example": 150 },
                "status": { "type": "string", "example": "completed" }
              }
            }
          }
        ],
        "responses": { "204": { "description": "No Content" } }
      },
      "delete": {
        "description": "Delete an order",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": { "204": { "description": "No Content" } }
      }
    }
  }
}